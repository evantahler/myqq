{
  "name": "@evantahler/myqq",
  "version": "0.1.1",
  "description": "TypeScript client for MyQ-enabled garage doors (Liftmaster / Chamberlain / Craftsman). Includes a stdio MCP server so AI agents can query and operate doors.",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "myqq-mcp": "src/mcp-server.ts"
  },
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/evantahler/myqq.git"
  },
  "keywords": [
    "myq",
    "garage-door",
    "liftmaster",
    "chamberlain",
    "craftsman",
    "smart-home",
    "mcp",
    "typescript"
  ],
  "author": "Evan Tahler",
  "scripts": {
    "test": "bun test",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome check --write .",
    "mcp": "bun run src/mcp-server.ts",
    "smoke": "bun run scripts/smoke.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  }
}
